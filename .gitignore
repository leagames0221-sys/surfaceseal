# ── PRIVATE track (dual-track leak defense, never commit) ──────────────
# Anchored to repo root so they do NOT swallow test fixtures that legitimately
# contain agent control-surface files (e.g. tests/fixtures/**/.claude/...).
/.claude/
/.tmp/
.env
.env.*
/notes/private/
/internal_notes/
/memory_bank/

# ── Python ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# ── video pipeline intermediates (final MP4 in video/out/ IS tracked) ──
video/_temp/
.vendor/
